{
  "hooks": [
    {
      "name": "rust-lambda-validate-before-deploy",
      "event": "PreToolUse",
      "tool": "Bash",
      "matcher": "cargo lambda deploy",
      "script": "hooks/validate-before-deploy.sh"
    },
    {
      "name": "rust-lambda-warn-no-env-vars",
      "event": "PreToolUse",
      "tool": "Bash",
      "matcher": "cargo lambda build",
      "script": "hooks/warn-hardcoded-resources.sh"
    }
  ]
}
